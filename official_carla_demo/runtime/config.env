# Minimal runtime configuration for the official CARLA pygame delivery package.
#
# This file replaces the old delivery/config.env dependency. It intentionally
# does not configure RTSP, ffplay, mediamtx, center-display, or watchdog units.

PROJECT_DIR="${CARLA_PROJECT_ROOT:-${HOME}/Carla_Project}"
CARLA_DIR="${CARLA_DIR:-${HOME}/CARLA_0.9.15}"
CONDA_ENV="${CONDA_ENV:-carla_vcu}"

CARLA_BACKEND_SCRIPT="${CARLA_BACKEND_SCRIPT:-official_carla_demo/official_demo_gateway.py}"
MANUAL_BRIDGE_SCRIPT="${MANUAL_BRIDGE_SCRIPT:-can_tcp_bridge_vcu.py}"
MANUAL_BRIDGE_STATUS_FILE="${MANUAL_BRIDGE_STATUS_FILE:-logs/manual_bridge_status.json}"
CARLA_TCP_CAN_HOST="${CARLA_TCP_CAN_HOST:-192.168.110.112}"
CARLA_TCP_CAN_PORT="${CARLA_TCP_CAN_PORT:-4001}"
CARLA_TCP_CAN_RECONNECT_SEC="${CARLA_TCP_CAN_RECONNECT_SEC:-3.0}"
CARLA_CAN_REVERSE_GEARS="${CARLA_CAN_REVERSE_GEARS:-4}"
CARLA_CAN_DRIVE_GEARS="${CARLA_CAN_DRIVE_GEARS:-2,3}"

# Prefer the stable ASCII alias created by install_autostart.sh, then fall
# back to whatever NJ0515 DBC name survived unzip.
if [ -n "${CARLA_CAN_DBC_OVERRIDE:-}" ]; then
  CARLA_CAN_DBC="${CARLA_CAN_DBC_OVERRIDE}"
elif [ -f "${PROJECT_DIR}/can/NJ0515.dbc" ]; then
  CARLA_CAN_DBC="can/NJ0515.dbc"
elif [ -d "${PROJECT_DIR}/can" ]; then
  CARLA_CAN_DBC="$(cd "${PROJECT_DIR}" && find can -maxdepth 1 -type f -name '*NJ0515.dbc' | head -n 1)"
  CARLA_CAN_DBC="${CARLA_CAN_DBC:-can/NJ0515.dbc}"
else
  CARLA_CAN_DBC="can/NJ0515.dbc"
fi

CARLA_HOST="${CARLA_HOST:-127.0.0.1}"
CARLA_PORT="${CARLA_PORT:-2000}"
CARLA_CONNECT_TIMEOUT="${CARLA_CONNECT_TIMEOUT:-10.0}"
CARLA_DEPLOY_TIMEOUT="${CARLA_DEPLOY_TIMEOUT:-60.0}"
CARLA_RUNTIME_TIMEOUT="${CARLA_RUNTIME_TIMEOUT:-20.0}"

API_PORT="${API_PORT:-8765}"
CENTER_DISPLAY_AUTO_START=0

# Sensor output is deliberately summarized and rate-limited so it does not
# compete with the main pygame camera, AI/AIGO, or manual control path.
OFFICIAL_ENABLE_SENSORS="${OFFICIAL_ENABLE_SENSORS:-1}"
OFFICIAL_SENSOR_UDP_PORTS="${OFFICIAL_SENSOR_UDP_PORTS:-5010}"
OFFICIAL_SENSOR_SUMMARY_HZ="${OFFICIAL_SENSOR_SUMMARY_HZ:-5}"
OFFICIAL_SENSOR_UDP_HZ="${OFFICIAL_SENSOR_UDP_HZ:-5}"
OFFICIAL_SENSOR_SAMPLE_LIMIT="${OFFICIAL_SENSOR_SAMPLE_LIMIT:-2048}"
OFFICIAL_SENSOR_LIDAR_MAX_PPS="${OFFICIAL_SENSOR_LIDAR_MAX_PPS:-300000}"
OFFICIAL_SENSOR_LIDAR_MAX_HZ="${OFFICIAL_SENSOR_LIDAR_MAX_HZ:-5}"

# AIGO path-following is timing-sensitive. Keep its control loop close to the
# known-good official_carla_demo baseline unless these are explicitly disabled.
OFFICIAL_AIGO_LIGHT_MODE="${OFFICIAL_AIGO_LIGHT_MODE:-1}"
OFFICIAL_AIGO_DISABLE_SENSORS="${OFFICIAL_AIGO_DISABLE_SENSORS:-1}"
OFFICIAL_AIGO_DISABLE_SIDE_MIRRORS="${OFFICIAL_AIGO_DISABLE_SIDE_MIRRORS:-0}"
OFFICIAL_AI_BASELINE_DISABLE_SENSORS="${OFFICIAL_AI_BASELINE_DISABLE_SENSORS:-1}"
OFFICIAL_AI_BASELINE_DISABLE_SIDE_MIRRORS="${OFFICIAL_AI_BASELINE_DISABLE_SIDE_MIRRORS:-0}"
OFFICIAL_SIDE_MIRRORS_ALWAYS_ON="${OFFICIAL_SIDE_MIRRORS_ALWAYS_ON:-1}"
OFFICIAL_DISABLE_SIDE_MIRRORS="${OFFICIAL_DISABLE_SIDE_MIRRORS:-1}"
OFFICIAL_SIDE_RTSP_HOST="${OFFICIAL_SIDE_RTSP_HOST:-192.168.110.100}"
OFFICIAL_SIDE_RTSP_PORT="${OFFICIAL_SIDE_RTSP_PORT:-8554}"
OFFICIAL_REAR_LEFT_STREAM_URL="${OFFICIAL_REAR_LEFT_STREAM_URL:-rtsp://192.168.110.100:8554/carla_rear_left}"
OFFICIAL_REAR_RIGHT_STREAM_URL="${OFFICIAL_REAR_RIGHT_STREAM_URL:-rtsp://192.168.110.100:8554/carla_rear_right}"
OFFICIAL_BIRDVIEW_STREAM_URL="${OFFICIAL_BIRDVIEW_STREAM_URL:-rtsp://192.168.110.100:8554/carla_birdview}"
OFFICIAL_AI_USE_MAP_SPAWN="${OFFICIAL_AI_USE_MAP_SPAWN:-0}"
OFFICIAL_AI_IGNORE_LIGHTS_PERCENT="${OFFICIAL_AI_IGNORE_LIGHTS_PERCENT:-0}"
OFFICIAL_AI_IGNORE_SIGNS_PERCENT="${OFFICIAL_AI_IGNORE_SIGNS_PERCENT:-0}"
OFFICIAL_AI_FALLBACK_ENABLED="${OFFICIAL_AI_FALLBACK_ENABLED:-0}"
OFFICIAL_TRAFFIC_MANAGER_PORT="${OFFICIAL_TRAFFIC_MANAGER_PORT:-8000}"
OFFICIAL_TERMINATE_TIMEOUT_SEC="${OFFICIAL_TERMINATE_TIMEOUT_SEC:-20.0}"
OFFICIAL_RELAUNCH_GAP_SEC="${OFFICIAL_RELAUNCH_GAP_SEC:-4.0}"
OFFICIAL_FIXED_DELTA_SECONDS="${OFFICIAL_FIXED_DELTA_SECONDS:-0.02}"
OFFICIAL_MAX_SUBSTEP_DELTA_TIME="${OFFICIAL_MAX_SUBSTEP_DELTA_TIME:-0.005}"
OFFICIAL_MAX_SUBSTEPS="${OFFICIAL_MAX_SUBSTEPS:-16}"
OFFICIAL_CAMERA_SENSOR_TICK="${OFFICIAL_CAMERA_SENSOR_TICK:-0.02}"
OFFICIAL_DISPLAY_LOOP_HZ="${OFFICIAL_DISPLAY_LOOP_HZ:-60}"
OFFICIAL_ROUTE_TM_SPEED_DIFFERENCE_PERCENT="${OFFICIAL_ROUTE_TM_SPEED_DIFFERENCE_PERCENT:-0}"
OFFICIAL_ROUTE_ARRIVAL_DISTANCE_M="${OFFICIAL_ROUTE_ARRIVAL_DISTANCE_M:-2.0}"
OFFICIAL_SIDE_STREAM_FPS="${OFFICIAL_SIDE_STREAM_FPS:-15.0}"
OFFICIAL_SIDE_CAMERA_WIDTH="${OFFICIAL_SIDE_CAMERA_WIDTH:-960}"
OFFICIAL_SIDE_CAMERA_HEIGHT="${OFFICIAL_SIDE_CAMERA_HEIGHT:-540}"

# CARLA engine window is deliberately not fullscreen; the pygame camera window
# is fullscreen and carries the demonstration view.
CARLA_DISPLAY="${CARLA_DISPLAY:-}"
CARLA_XAUTHORITY="${CARLA_XAUTHORITY:-}"
CARLA_FULLSCREEN="${CARLA_FULLSCREEN:-0}"
CARLA_RESOLUTION="${CARLA_RESOLUTION:-1920x1080}"
CARLA_RENDER_OFFSCREEN="${CARLA_RENDER_OFFSCREEN:-0}"
CARLA_QUALITY_LEVEL="${CARLA_QUALITY_LEVEL:-Epic}"
CARLA_EXTRA_ARGS="${CARLA_EXTRA_ARGS:--windowed -vulkanpresentmode=2}"
OFFICIAL_KILL_STALE_CARLA="${OFFICIAL_KILL_STALE_CARLA:-1}"

RUNTIME_STATE_DIR="${HOME}/.local/state/official_carla_demo"
