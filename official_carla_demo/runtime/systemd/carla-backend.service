[Unit]
Description=Official CARLA Demo Backend
After=network-online.target carla-engine.service
Wants=network-online.target
Requires=carla-engine.service
StartLimitIntervalSec=300
StartLimitBurst=3

[Service]
Type=simple
WorkingDirectory=%h/Carla_Project
ExecStart=/usr/bin/env bash %h/Carla_Project/official_carla_demo/start_backend_service.sh
Restart=on-failure
RestartSec=10
KillSignal=SIGTERM
TimeoutStopSec=20

[Install]
WantedBy=default.target
