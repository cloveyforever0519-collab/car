# CARLA mirror video stream configuration.
# This file is sourced by delivery/start_mirror_stream.sh.

MIRROR_WIDTH="1280"
MIRROR_HEIGHT="720"
MIRROR_FPS="20"
MIRROR_BITRATE="5000k"
MIRROR_BUFSIZE="5000k"
MIRROR_QUEUE_SIZE="1"
MIRROR_STALE_FRAME_SEC="0.35"

# Public address provided to the 192.168.110.103 client.
MIRROR_RTSP_PUBLIC_HOST="${DELIVERY_IP:-192.168.110.100}"
MIRROR_RTSP_HOST="127.0.0.1"
MIRROR_RTSP_PORT="8554"

# Set to h264_nvenc, libx264, or auto.
MIRROR_ENCODER="auto"

# Rear-view clients sometimes expect mirror-like horizontal flip.
# Keep off by default. Change to 1 only if 103 displays left/right reversed.
MIRROR_HFLIP="0"

MIRROR_SINGLE_ACTIVE_VIEW="0"
MIRROR_ACTIVE_VIEW_PATH="carla_view"
MIRROR_ENABLE_VIEW_STREAMS="0"
MIRROR_ENABLE_REAR_STREAMS="1"
MIRROR_ENABLE_BIRDVIEW_STREAM="1"
MIRROR_BIRDVIEW_PATH="carla_birdview"
MIRROR_BIRDVIEW_FOV="96.0"

MIRROR_HEALTH_URL="http://127.0.0.1:${API_PORT:-8765}/health"
MIRROR_STATUS_FILE="${PROJECT_DIR:-${HOME}/Carla_Project}/logs/mirror_stream_status.json"

# Optional path overrides.
MIRROR_FFMPEG_BIN="ffmpeg"
MIRROR_MEDIAMTX_BIN="${PROJECT_DIR:-${HOME}/Carla_Project}/bin/mediamtx"
MIRROR_MEDIAMTX_CONFIG="${PROJECT_DIR:-${HOME}/Carla_Project}/delivery/mediamtx.yml"
