# Delivery runtime configuration.
# Copy this project to /home/zhang/Carla_Project on the delivery Ubuntu host.

PROJECT_DIR="${HOME}/Carla_Project"
CARLA_DIR="${HOME}/CARLA_0.9.15"
CONDA_ENV="carla_vcu"
CARLA_BACKEND_SCRIPT="${CARLA_BACKEND_SCRIPT:-main_gui.py}"
MANUAL_BRIDGE_SCRIPT="${MANUAL_BRIDGE_SCRIPT:-can_tcp_bridge_vcu.py}"
MANUAL_BRIDGE_STATUS_FILE="${MANUAL_BRIDGE_STATUS_FILE:-logs/manual_bridge_status.json}"
CARLA_CAN_DBC="${CARLA_CAN_DBC:-can/智能座舱CAN协议-NJ0515.dbc}"
CARLA_TCP_CAN_HOST="${CARLA_TCP_CAN_HOST:-192.168.110.112}"
CARLA_TCP_CAN_PORT="${CARLA_TCP_CAN_PORT:-4001}"
CARLA_TCP_CAN_RECONNECT_SEC="${CARLA_TCP_CAN_RECONNECT_SEC:-3.0}"
CARLA_CAN_REVERSE_GEARS="${CARLA_CAN_REVERSE_GEARS:-4,0}"
CARLA_CAN_DRIVE_GEARS="${CARLA_CAN_DRIVE_GEARS:-2,3}"

CARLA_HOST="127.0.0.1"
CARLA_PORT="2000"
CARLA_CONNECT_TIMEOUT="10.0"
CARLA_DEPLOY_TIMEOUT="60.0"
CARLA_RUNTIME_TIMEOUT="20.0"

API_PORT="8765"
STREAMLIT_PORT="8501"
DELIVERY_IP="192.168.110.100"
CENTER_DISPLAY_PLAYER="${CENTER_DISPLAY_PLAYER:-auto}"
CENTER_DISPLAY_URL="${CENTER_DISPLAY_URL:-rtsp://${DELIVERY_IP}:8554/carla_view}"
CENTER_DISPLAY_AUTO_START="${CENTER_DISPLAY_AUTO_START:-1}"
CENTER_DISPLAY_POLL_SEC="${CENTER_DISPLAY_POLL_SEC:-1}"
CENTER_DISPLAY_WAIT_FOR_VEHICLE="${CENTER_DISPLAY_WAIT_FOR_VEHICLE:-1}"
CENTER_DISPLAY_STOP_WHEN_STREAM_NOT_READY="${CENTER_DISPLAY_STOP_WHEN_STREAM_NOT_READY:-1}"
CENTER_DISPLAY_ALWAYS_ON_TOP="${CENTER_DISPLAY_ALWAYS_ON_TOP:-1}"

# CARLA is a graphical Unreal application. Leave display values empty by
# default so delivery/start_carla.sh can auto-detect the active X11 session.
# Override these only if the delivery host uses a fixed display layout.
CARLA_DISPLAY="${CARLA_DISPLAY:-}"
CARLA_XAUTHORITY="${CARLA_XAUTHORITY:-}"

# CARLA display mode. "auto" uses the active X11 monitor resolution.
CARLA_FULLSCREEN="${CARLA_FULLSCREEN:-1}"
CARLA_RESOLUTION="${CARLA_RESOLUTION:-auto}"
CARLA_RENDER_OFFSCREEN="${CARLA_RENDER_OFFSCREEN:-0}"
CARLA_QUALITY_LEVEL="${CARLA_QUALITY_LEVEL:-Low}"
CARLA_EXTRA_ARGS="${CARLA_EXTRA_ARGS:--windowed -vulkanpresentmode=2}"

# Health watchdog policy.
WATCHDOG_FAILURE_LIMIT="3"
WATCHDOG_CARLA_RESTART_COOLDOWN_SEC="120"
WATCHDOG_STATE_DIR="${HOME}/.local/state/carla_delivery"
